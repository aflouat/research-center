<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>نموذج التوصيل موريتانيا 2026</title>
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&family=Tajawal:wght@400;700&display=swap" rel="stylesheet">
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { font-family: 'Cairo', sans-serif; }
    </style>
</head>
<body class="bg-gray-50 text-gray-800">

    <!-- Header -->
    <header class="bg-green-600 text-white py-10 shadow-lg">
        <div class="container mx-auto px-6 text-center">
            <h1 class="text-4xl font-bold mb-4">نموذج التوصيل الفائق - موريتانيا 2026</h1>
            <p class="text-xl opacity-90">دليل استراتيجي للنمو والربحية في السوق الموريتاني</p>
        </div>
    </header>

    <main class="container mx-auto px-6 py-12">
        
        <!-- Summary Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
            <div class="bg-white p-8 rounded-xl shadow-md text-center border-t-4 border-green-500">
                <h3 class="text-lg font-bold text-gray-500 mb-2">حجم السوق المقدر</h3>
                <p class="text-3xl font-extrabold text-green-600">80M €</p>
            </div>
            <div class="bg-white p-8 rounded-xl shadow-md text-center border-t-4 border-blue-500">
                <h3 class="text-lg font-bold text-gray-500 mb-2">نقطة التعادل (يومياً)</h3>
                <p class="text-3xl font-extrabold text-blue-600">500 طلب</p>
            </div>
            <div class="bg-white p-8 rounded-xl shadow-md text-center border-t-4 border-yellow-500">
                <h3 class="text-lg font-bold text-gray-500 mb-2">طرق الدفع الرقمي</h3>
                <p class="text-3xl font-extrabold text-yellow-600">85%</p>
            </div>
        </div>

        <!-- Charts Section -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-16">
            <!-- Chart 1 -->
            <div class="bg-white p-6 rounded-xl shadow-md">
                <h2 class="text-xl font-bold mb-6 text-right">توزيع الطلبات حسب القطاع (2026)</h2>
                <canvas id="verticalsChart"></canvas>
            </div>
            <!-- Chart 2 -->
            <div class="bg-white p-6 rounded-xl shadow-md">
                <h2 class="text-xl font-bold mb-6 text-right">طرق الدفع المفضلة</h2>
                <canvas id="paymentsChart"></canvas>
            </div>
        </div>

        <!-- Strategy Section -->
        <section class="bg-white p-10 rounded-xl shadow-md mb-16">
            <h2 class="text-2xl font-bold mb-8 text-green-700">الركائز الثلاث للنجاح</h2>
            <div class="space-y-6">
                <div class="flex items-start">
                    <div class="bg-green-100 p-3 rounded-lg ml-4">
                        <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <div>
                        <h4 class="text-xl font-bold">التكامل مع Bankily & Masrvi</h4>
                        <p class="text-gray-600 mt-1">الربط البرمجي المباشر مع التطبيقات البنكية لتقليل التعاملات النقدية وتسريع وتيرة التوصيل.</p>
                    </div>
                </div>
                <div class="flex items-start">
                    <div class="bg-blue-100 p-3 rounded-lg ml-4">
                        <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A2 2 0 013 15.492V4.508a2 2 0 011.553-1.954l5.447 2.724A2 2 0 0011 5.492v10.984a2 2 0 00.553 1.954l5.447 2.724A2 2 0 0021 18.508V7.508a2 2 0 00-1.553-1.954l-5.447-2.724A2 2 0 0113 4.508v10.984a2 2 0 01-.553 1.954L9 20z"></path></svg>
                    </div>
                    <div>
                        <h4 class="text-xl font-bold">الذكاء الجغرافي المحلي</h4>
                        <p class="text-gray-600 mt-1">تطوير نظام خرائط يعتمد على المعالم البارزة (Repères) لتجاوز عقبة غياب العناوين الدقيقة في نواكشوط.</p>
                    </div>
                </div>
                <div class="flex items-start">
                    <div class="bg-purple-100 p-3 rounded-lg ml-4">
                        <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    </div>
                    <div>
                        <h4 class="text-xl font-bold">النموذج متعدد الخدمات (Multi-Vertical)</h4>
                        <p class="text-gray-600 mt-1">عدم الاقتصار على الطعام؛ توصيل الغاز، الأدوية، والطرود بين الشركات لضمان تشغيل الأسطول طوال اليوم.</p>
                    </div>
                </div>
            </div>
        </section>

    </main>

    <footer class="bg-gray-800 text-white py-8 text-center">
        <p>© 2026 - رؤية استراتيجية للسوق الموريتاني | تطوير هندسي متقدم</p>
    </footer>

    <script>
        // Vertical Chart
        const ctx1 = document.getElementById('verticalsChart').getContext('2d');
        new Chart(ctx1, {
            type: 'bar',
            data: {
                labels: ['مطاعم', 'بقالة/تموين', 'غاز', 'صيدلية', 'طرود B2B'],
                datasets: [{
                    label: 'النسبة المئوية %',
                    data: [40, 25, 15, 10, 10],
                    backgroundColor: ['#10B981', '#3B82F6', '#F59E0B', '#EF4444', '#8B5CF6']
                }]
            },
            options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
        });

        // Payments Chart
        const ctx2 = document.getElementById('paymentsChart').getContext('2d');
        new Chart(ctx2, {
            type: 'doughnut',
            data: {
                labels: ['Bankily / Masrvi', 'نقداً عند الاستلام', 'بطاقات بنكية'],
                datasets: [{
                    data: [75, 20, 5],
                    backgroundColor: ['#10B981', '#6B7280', '#3B82F6']
                }]
            }
        });
    </script>
</body>
</html>
